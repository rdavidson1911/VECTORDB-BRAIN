APP_NAME=omnikb-api
APP_ENV=dev
API_PORT=8000

QDRANT_URL=http://qdrant:6333
QDRANT_PORT=6333
QDRANT_COLLECTION=omnikb_documents
QDRANT_TIMEOUT_SECONDS=15

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_STRATEGY=recursive_char_v1
CHUNK_SIZE=450
CHUNK_OVERLAP=60
PIPELINE_VERSION=0.1.0
NORMALIZATION_PROFILE=utf8_ignore_pypdf_v1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Playwright smoke (web/npm run smoke:playwright) — first ingest/query can be slow on cold start
# INGEST_TIMEOUT_MS=120000
# QUERY_TIMEOUT_MS=120000

# Windows-friendly relative paths for Docker Desktop bind mounts.
DATA_SOURCES_PATH=./data/sources
# Optional: host path for the same folder (maps Windows paths to DATA_SOURCES_PATH in API).
# Recommended on Windows when pasting host paths into the UI (optional if paths include /data/sources/):
HOST_DATA_SOURCES_PATH=I:/VECTORDB-BRAIN/data/sources
QDRANT_STORAGE_PATH=./data/qdrant
PROCESSED_DATA_PATH=./data/processed

# Curation gate (hard block on ingest when validation errors exist under gate roots)
CURATION_GATE_ENABLED=true
# Comma-separated folder names under data/sources (default: curated only)
CURATION_GATE_ROOTS=curated
# Must be true to honor allow_quality_override on POST /ingest/path and /ingest/file
CURATION_ALLOW_OVERRIDE=false

# Local SMTP (MailCatcher — docker compose --profile dev-mail up -d mailcatcher)
# No TLS/auth; localhost only. Never use in production.
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# From inside the api container when dev-mail profile is up: SMTP_HOST=mailcatcher
# MAILCATCHER_WEB=http://127.0.0.1:1081
# MAILCATCHER_SMTP_PORT=1025
# MAILCATCHER_WEB_PORT=1081
